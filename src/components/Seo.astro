---
import { getAbsoluteLocaleUrl } from 'astro:i18n';
import { LOCALES, type Locale } from '../i18n';
import { HREFLANG, OG_LOCALE } from '../i18n/localeMeta';

interface Props {
  title: string;
  description: string;
  /** Route path after locale (e.g. `services/mobile` or empty string for home). */
  path: string;
  lang: Locale;
  image?: string;
}

const { title, description, path, lang, image } = Astro.props;

const canonical = getAbsoluteLocaleUrl(lang, path ? path : undefined);
---

<meta name="description" content={description} />
<link rel="canonical" href={canonical} />

<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:locale" content={OG_LOCALE[lang]} />
{image ? <meta property="og:image" content={image} /> : null}

<meta name="twitter:card" content={image ? 'summary_large_image' : 'summary'} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{image ? <meta name="twitter:image" content={image} /> : null}

{
  LOCALES.map((loc) => (
    <link
      rel="alternate"
      hreflang={HREFLANG[loc]}
      href={getAbsoluteLocaleUrl(loc, path ? path : undefined)}
    />
  ))
}
<link rel="alternate" hreflang="x-default" href={getAbsoluteLocaleUrl('en', path ? path : undefined)} />
