---
interface Props {
  title: string;
  summary: string;
  href: string;
  learnMore: string;
}

const { title, summary, href, learnMore } = Astro.props;
---

<article
  class="group flex flex-col rounded-2xl border border-border bg-surface p-6 shadow-sm shadow-text/5 transition hover:border-accent/25 hover:shadow-md"
>
  <h3 class="font-serif text-xl font-semibold text-text">{title}</h3>
  <p class="mt-3 flex-1 text-subtle">{summary}</p>
  <a
    href={href}
    class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-accent no-underline group-hover:text-accent-hover"
  >
    {learnMore}
    <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">→</span>
  </a>
</article>
