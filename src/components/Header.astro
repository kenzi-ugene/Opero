---
import { getRelativeLocaleUrl } from 'astro:i18n';
import type { Locale } from '../i18n';
import type { Messages } from '../i18n/types';
import { t } from '../i18n/utils';
import LocaleSwitcher from './LocaleSwitcher.astro';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  lang: Locale;
  dict: Messages;
}

const { lang, dict } = Astro.props;

const home = getRelativeLocaleUrl(lang);
const services = getRelativeLocaleUrl(lang, 'services');
const about = getRelativeLocaleUrl(lang, 'about');
const contact = getRelativeLocaleUrl(lang, 'contact');
---

<header
  class="sticky top-0 z-50 border-b border-border/80 bg-page/90 backdrop-blur-md supports-[backdrop-filter]:bg-page/75"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-4 py-3.5 md:gap-4 md:px-6">
    <a href={home} class="group flex min-w-0 flex-col no-underline">
      <span class="font-serif text-xl font-semibold tracking-tight text-text group-hover:text-accent">
        {dict.brand}
      </span>
      <span class="hidden truncate text-xs text-subtle sm:block">{dict.tagline}</span>
    </a>

    <div class="flex shrink-0 items-center gap-2 md:gap-3">
      <ThemeToggle dict={dict} />
      <LocaleSwitcher lang={lang} dict={dict} />

      <nav class="hidden items-center gap-5 lg:flex" aria-label="Primary">
        <a href={home} class="text-sm font-medium text-muted no-underline hover:text-accent">
          {t(dict, 'nav.home')}
        </a>
        <a href={services} class="text-sm font-medium text-muted no-underline hover:text-accent">
          {t(dict, 'nav.services')}
        </a>
        <a href={about} class="text-sm font-medium text-muted no-underline hover:text-accent">
          {t(dict, 'nav.about')}
        </a>
        <a
          href={contact}
          class="rounded-lg bg-accent px-4 py-2 text-sm font-semibold text-on-accent no-underline hover:bg-accent-hover"
        >
          {t(dict, 'nav.contact')}
        </a>
      </nav>

      <details class="relative lg:hidden">
        <summary
          class="list-none cursor-pointer rounded-lg border border-border bg-surface px-3 py-2 text-sm text-muted [&::-webkit-details-marker]:hidden"
          aria-label={t(dict, 'nav.openMenu')}
        >
          Menu
        </summary>
        <div
          class="absolute right-0 z-50 mt-2 w-52 rounded-xl border border-border bg-surface p-2 shadow-lg shadow-text/5"
        >
          <nav class="flex flex-col gap-0.5" aria-label="Mobile">
            <a href={home} class="rounded-lg px-3 py-2 text-muted no-underline hover:bg-surface-muted">
              {t(dict, 'nav.home')}
            </a>
            <a href={services} class="rounded-lg px-3 py-2 text-muted no-underline hover:bg-surface-muted">
              {t(dict, 'nav.services')}
            </a>
            <a href={about} class="rounded-lg px-3 py-2 text-muted no-underline hover:bg-surface-muted">
              {t(dict, 'nav.about')}
            </a>
            <a
              href={contact}
              class="rounded-lg bg-accent px-3 py-2 text-center text-sm font-semibold text-on-accent no-underline hover:bg-accent-hover"
            >
              {t(dict, 'nav.contact')}
            </a>
          </nav>
        </div>
      </details>
    </div>
  </div>
</header>
