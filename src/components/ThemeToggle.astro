---
import type { Messages } from '../i18n/types';

interface Props {
  dict: Messages;
}

const { dict } = Astro.props;
---

<button
  type="button"
  class="theme-toggle inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-lg border border-border bg-surface text-muted transition hover:bg-surface-muted hover:text-text"
  aria-label={dict.nav.themeToggle}
>
  <span class="hidden dark:inline-flex" aria-hidden="true">
    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
      />
    </svg>
  </span>
  <span class="inline-flex dark:hidden" aria-hidden="true">
    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
      />
    </svg>
  </span>
</button>

<script>
  const STORAGE_KEY = 'opero-theme';

  function applyTheme(dark: boolean) {
    document.documentElement.classList.toggle('dark', dark);
    localStorage.setItem(STORAGE_KEY, dark ? 'dark' : 'light');
  }

  document.querySelectorAll<HTMLButtonElement>('.theme-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      applyTheme(!document.documentElement.classList.contains('dark'));
    });
  });
</script>
