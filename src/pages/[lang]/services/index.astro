---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ServiceCard from '../../../components/ServiceCard.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { messages, type Locale, LOCALES } from '../../../i18n';
import { SERVICE_SLUGS } from '../../../data/services';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang: langParam } = Astro.params;
const lang = langParam as Locale;
const dict = messages[lang];

const seo = dict.seo.services;
---

<BaseLayout
  lang={lang}
  dict={dict}
  title={seo.title}
  description={seo.description}
  seoPath="services"
>
  <div class="mx-auto max-w-6xl px-4 py-14 md:px-6 md:py-20">
    <h1 class="font-serif text-4xl font-semibold tracking-tight text-text md:text-5xl">
      {dict.services.indexHeading}
    </h1>
    <p class="mt-4 max-w-2xl text-lg text-subtle">{dict.services.indexLead}</p>

    <div class="mt-12 grid gap-6 sm:grid-cols-2">
      {
        SERVICE_SLUGS.map((slug) => (
          <ServiceCard
            title={dict.services.detail[slug].title}
            summary={dict.services.summaries[slug]}
            href={getRelativeLocaleUrl(lang, `services/${slug}`)}
            learnMore={dict.services.learnMore}
          />
        ))
      }
    </div>
  </div>
</BaseLayout>
